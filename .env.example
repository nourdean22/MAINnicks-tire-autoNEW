# ═══════════════════════════════════════════════
# Nick's Tire & Auto — Environment Variables
# Copy to .env and fill in values
# ═══════════════════════════════════════════════

# ─── Server ───────────────────────────────────
NODE_ENV=development
PORT=3000
SITE_URL=https://nickstire.org

# ─── Database (MySQL / TiDB) ─────────────────
DATABASE_URL=mysql://user:password@host:port/database

# ─── Twilio (SMS) ────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
OWNER_PHONE_NUMBER=

# ─── Authentication ──────────────────────────
JWT_SECRET=change-this-to-a-random-string
ADMIN_API_KEY=change-this-to-a-random-string  # Required for /api/ai/* admin endpoints

# ─── Google APIs ─────────────────────────────
GOOGLE_SHEETS_CREDENTIALS=
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_REVIEWS_API_KEY=
GOOGLE_MAPS_API_KEY=

# ─── Google OAuth (Admin Login) ─────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# ─── AI / LLM ──────────────────────────────────
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com  # Override for custom endpoints

# ─── Ollama (Local AI) ─────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434  # Default if Ollama is running
# Local models: dolphin-nour, dolphin-nour-deep, phi4-mini, sqlcoder:7b, gemma3:4b

# ─── AI (Gemini — legacy) ──────────────────────
GEMINI_API_KEY=

# ─── Meta / Facebook ─────────────────────────
META_PIXEL_ID=1436350367898578
META_ACCESS_TOKEN=
META_CONVERSIONS_API_TOKEN=

# ─── AWS S3 (File Storage) ───────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=

# ─── Email (Resend) ─────────────────────────
EMAIL_FROM=Nick's Tire & Auto <noreply@nickstire.org>
RESEND_API_KEY=
SHOP_EMAIL=
CEO_EMAIL=

# ─── NOUR OS Bridge ────────────────────────
NOUR_OS_API_URL=https://autonicks.com

# ─── Cron ──────────────────────────────────────
CRON_SECRET=              # Shared secret for /api/cron/* trigger endpoint

# ─── Remote Access ─────────────────────────────
TUNNEL_URL=               # Cloudflare tunnel URL (auto-set by startup scripts)

# ─── Redis (Optional — falls back to memory) ─
REDIS_URL=

# ─── Error Tracking (Optional) ───────────────
SENTRY_DSN=

# ─── Analytics ───────────────────────────────
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ─── Feature Flags (all start DISABLED) ──────
# Set to "true" to enable
ENABLE_SMS_REVIEW_REQUESTS=false
ENABLE_SMS_APPOINTMENT_REMINDERS=false
ENABLE_SMS_RETENTION_SEQUENCES=false
ENABLE_AI_RECEPTIONIST=false
ENABLE_DRIP_CAMPAIGNS=false
ENABLE_AUTO_REVIEW_RESPONSES=false
ENABLE_PREDICTIVE_MAINTENANCE=false
ENABLE_EMAIL_CAMPAIGNS=false
ENABLE_GBP_AUTO_POSTING=false
ENABLE_SMS_BLASTS=false
ENABLE_SMART_SMS_AUTO_REPLY=false
