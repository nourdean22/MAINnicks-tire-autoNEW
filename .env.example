# ═══════════════════════════════════════════════
# Nick's Tire & Auto — Environment Variables
# Copy to .env and fill in values
# ═══════════════════════════════════════════════

# ─── Server (required) ──────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database (required) ────────────────────────
DATABASE_URL=mysql://user:password@host:port/database

# ─── Authentication (required) ──────────────────
JWT_SECRET=change-this-to-a-random-string
ADMIN_API_KEY=change-this-to-a-random-string

# ─── Google OAuth (required for admin login) ────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Client-side (must be VITE_ prefixed — same value as GOOGLE_OAUTH_CLIENT_ID)
VITE_GOOGLE_OAUTH_CLIENT_ID=
# Owner's Google OpenID (format: google:123456789 — auto-promotes to admin on first login)
OWNER_OPEN_ID=

# ─── AI / LLM (required for AI features) ────────
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com    # Override for custom endpoints
# OLLAMA_BASE_URL=http://localhost:11434     # Default if Ollama is running locally

# ─── Twilio SMS (optional — SMS features) ───────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
# OWNER_PHONE_NUMBER=
# OWNER_PHONE=                               # Alternative owner phone reference

# ─── Google Services (optional) ─────────────────
# GOOGLE_SHEETS_CRM_ID=                      # Spreadsheet ID for CRM sync
# GOOGLE_WORKSPACE_CLI_TOKEN=                # For Sheets API auth
# GOOGLE_MAPS_API_KEY=                       # Maps embed
# GOOGLE_PLACES_API_KEY=                     # Reviews API
# GOOGLE_DRIVE_TOKEN=                        # Drive integration

# ─── Email (optional — Resend) ──────────────────
# EMAIL_FROM=Nick's Tire & Auto <noreply@nickstire.org>
# RESEND_API_KEY=
# SHOP_EMAIL=
# CEO_EMAIL=

# ─── Meta / Facebook (optional) ─────────────────
# META_PIXEL_ID=1436350367898578
# META_CAPI_ACCESS_TOKEN=
# FB_PAGE_ACCESS_TOKEN=                      # Messenger bot
# FB_VERIFY_TOKEN=                           # Messenger webhook verify

# ─── AWS S3 (optional — file uploads) ───────────
# S3_BUCKET=                                  # S3 bucket name for file uploads
# CLOUDFRONT_DOMAIN=
# AWS_REGION=us-east-1

# ─── NOUR OS Bridge (optional) ──────────────────
# NOUR_OS_API_URL=https://autonicks.com
# NOUR_OS_EVENTS_PATH=

# ─── Statenour Sync (optional) ──────────────────
# STATENOUR_SYNC_URL=
# STATENOUR_SYNC_KEY=

# ─── Gateway Tire Integration (optional) ────────
# GATEWAY_TIRE_USERNAME=
# GATEWAY_TIRE_PASSWORD=

# ─── Auto Labor Integration (optional) ──────────
# AUTO_LABOR_USERNAME=
# AUTO_LABOR_PASSWORD=

# ─── Stripe (optional — payments) ───────────────
# STRIPE_SECRET_KEY=

# ─── Cron / Background Jobs ─────────────────────
# CRON_SECRET=                               # Shared secret for /api/cron/* triggers
# CRON_EXTERNAL=                             # Set to "true" on Railway (uses external cron)

# ─── Remote Access ───────────────────────────────
# TUNNEL_URL=                                # Cloudflare tunnel URL (auto-set by scripts)

# ─── Observability (optional) ───────────────────
# LOG_LEVEL=info                             # debug | info | warn | error
# REDIS_URL=                                 # Falls back to in-memory cache
# NOTIFICATION_WEBHOOK_URL=                  # Slack/Discord webhook for alerts

# ─── Telegram Alerts (optional) ─────────────────
# TELEGRAM_BOT_TOKEN=                        # Telegram bot for push alerts to owner
# TELEGRAM_CHAT_ID=                          # Chat ID for owner notifications

# ─── NOUR OS Bridge (optional) ──────────────────
# BRIDGE_API_KEY=                            # Shared secret for NOUR OS bridge endpoints
# GOOGLE_PLACE_ID=                           # Google Place ID for competitor monitoring

# ─── Legacy / Rarely Used ───────────────────────
# OWNER_OPEN_ID=                             # Google OAuth openId for admin bootstrap
# YOUTUBE_API_KEY=                           # YouTube integration
