# ═══════════════════════════════════════════════
# Nick's Tire & Auto — Environment Variables
# Copy to .env and fill in values
# ═══════════════════════════════════════════════

# Classification legend:
# [LOCAL+PROD REQUIRED] required for both local development and production runtime
# [PROD REQUIRED] required in production but may be mocked/omitted locally
# [OPTIONAL] optional integration or feature-specific setting
# [HOST PROVIDED] provided by platform (Railway) and should not be set manually

# Usage rules:
# 1) Never commit real secrets.
# 2) For any new required runtime variable, add it here and to scripts/env-validate.mjs.
# 3) Optional integration variables should include a comment for fallback behavior.
# 4) Host-provided variables (Railway) should remain commented and unmanaged locally.

# ─── Server [LOCAL+PROD REQUIRED] ───────────────
NODE_ENV=development
PORT=3000

# ─── Database [LOCAL+PROD REQUIRED] ─────────────
DATABASE_URL=mysql://user:password@host:port/database

# ─── Authentication [LOCAL+PROD REQUIRED] ───────
JWT_SECRET=change-this-to-a-random-string
ADMIN_API_KEY=change-this-to-a-random-string

# ─── Google OAuth [PROD REQUIRED for admin login] ─
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
# Owner's Google OpenID (format: google:123456789 — auto-promotes to admin on first login)
OWNER_OPEN_ID=google:your-numeric-id

# ─── Client-side [LOCAL+PROD REQUIRED where used] ─
# Same value as GOOGLE_OAUTH_CLIENT_ID
VITE_GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
# Public site URL for SEO meta tags (default: https://nickstire.org)
# VITE_SITE_URL=https://nickstire.org
# FrontendForge map embed
# VITE_FRONTEND_FORGE_API_KEY=your-frontend-forge-api-key
# VITE_FRONTEND_FORGE_API_URL=https://your-frontend-forge-url

# ─── PWA Push Notifications (optional) ──────────
# Generate with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=your-vapid-public-key
# VAPID_PRIVATE_KEY=your-vapid-private-key
# VAPID_EMAIL=mailto:nourdean22@gmail.com

# ─── AI / LLM [PROD REQUIRED for AI features] ─────
# Venice AI is the primary provider. OpenAI is the fallback.
VENICE_API_KEY=your-venice-api-key
OPENAI_API_KEY=your-openai-api-key
LLM_MODEL=llama-3.3-70b
# OPENAI_BASE_URL=https://api.venice.ai/api/v1   # Set to Venice for invokeLLM() path
# VENICE_BASE_URL=https://api.venice.ai/api/v1   # Venice API base (default)

# ─── Email (optional — Resend) ──────────────────
# EMAIL_FROM=Nick's Tire & Auto <noreply@nickstire.org>
# RESEND_API_KEY=re_your-resend-api-key
# SHOP_EMAIL=shop@nickstire.org                   # Public shop contact email
# CEO_EMAIL=owner@nickstire.org                   # Owner/CEO email for escalations

# ─── Twilio SMS (optional) ─────────────────────
# TWILIO_ACCOUNT_SID=your-twilio-account-sid
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_PHONE_NUMBER=+12165551234               # Twilio number that sends SMS
# OWNER_PHONE_NUMBER=+12168620005                # Owner phone for alerts & daily reports

# ─── Telegram Alerts (optional) ─────────────────
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token      # Telegram bot for push alerts to owner
# TELEGRAM_CHAT_ID=your-telegram-chat-id          # Chat ID for owner notifications

# ─── Meta / Facebook (optional) ─────────────────
# META_PIXEL_ID=your-meta-pixel-id                # Facebook Pixel ID for tracking
# META_CAPI_ACCESS_TOKEN=your-meta-capi-token     # Conversions API access token
# FB_PAGE_ACCESS_TOKEN=your-fb-page-token         # Messenger bot
# FB_VERIFY_TOKEN=your-fb-verify-token            # Messenger webhook verify
# FB_APP_SECRET=your-fb-app-secret                # HMAC verification for Messenger webhook
# META_PAGE_ACCESS_TOKEN=your-page-token          # Long-lived Page token (pages_manage_posts, instagram_content_publish)
# META_PAGE_ID=your-facebook-page-id              # Facebook Page ID for posting
# META_IG_USER_ID=your-ig-business-account-id     # Instagram Business Account ID (linked to FB page)

# ─── Google Analytics (optional) ────────────────
# GA4_MEASUREMENT_ID=G-XXXXXXXXXX                 # GA4 measurement ID for server-side events
# GA4_API_SECRET=your-ga4-api-secret              # GA4 Measurement Protocol secret

# ─── Google Services (optional) ─────────────────
# GOOGLE_MAPS_API_KEY=your-google-maps-key        # Maps embed on site
# GOOGLE_PLACES_API_KEY=your-google-places-key    # Reviews API & competitor monitoring
# GOOGLE_PLACE_ID=your-google-place-id            # Nick's Google Place ID for review tracking

# ─── Google Sheets / Drive (optional — CRM sync) ─
# GOOGLE_SHEETS_CRM_ID=your-spreadsheet-id        # Spreadsheet ID for CRM sync
# GOOGLE_SPREADSHEET_ID=your-spreadsheet-id       # Spreadsheet ID for vendor health
# GOOGLE_DRIVE_TOKEN=your-google-drive-token       # Drive/Sheets API auth token
# GOOGLE_WORKSPACE_CLI_TOKEN=your-cli-token        # Alternative Sheets API auth

# ─── AWS S3 / CloudFront (optional — file uploads) ─
# S3_BUCKET=your-s3-bucket-name                   # S3 bucket for file uploads
# AWS_REGION=us-east-1                            # AWS region
# CLOUDFRONT_DOMAIN=your-cloudfront-domain        # CDN domain for uploaded assets

# ─── Stripe (optional — payments) ───────────────
# STRIPE_SECRET_KEY=sk_your-stripe-secret-key     # Stripe secret key for server-side
# STRIPE_PUBLISHABLE_KEY=pk_your-stripe-pub-key   # Stripe publishable key for client-side
# VITE_STRIPE_PUBLISHABLE_KEY=pk_your-stripe-pub   # Same key exposed to Vite client

# ─── NOUR OS Bridge (optional) ──────────────────
# NOUR_OS_API_URL=https://autonicks.com           # NOUR OS base URL
# NOUR_OS_EVENTS_PATH=/api/events                 # Events endpoint path
# BRIDGE_API_KEY=your-bridge-api-key              # Shared secret for cross-system bridge

# ─── Statenour Sync (optional) ──────────────────
# STATENOUR_SYNC_URL=https://statenour-os.vercel.app
# STATENOUR_SYNC_KEY=your-statenour-sync-key      # Auth key for statenour sync

# ─── Gateway Tire Integration (optional) ────────
# GATEWAY_TIRE_USERNAME=your-gateway-tire-username
# GATEWAY_TIRE_PASSWORD=your-gateway-tire-password

# ─── Auto Labor / ShopDriver Integration (optional) ─
# AUTO_LABOR_USERNAME=your-auto-labor-username
# AUTO_LABOR_PASSWORD=your-auto-labor-password

# ─── Weather Intelligence (optional) ────────────
# OPENWEATHER_API_KEY=your-openweather-api-key    # OpenWeather API for weather-based marketing

# ─── YouTube (optional) ────────────────────────
# YOUTUBE_API_KEY=your-youtube-api-key            # YouTube integration

# ─── Cron / Background Jobs [PROD REQUIRED if enabled] ─
# CRON_SECRET=your-cron-secret                    # Shared secret for /api/cron/* triggers
# CRON_EXTERNAL=true                              # Set to "true" on Railway (uses external cron)

# ─── Remote Access ───────────────────────────────
# TUNNEL_URL=https://your-tunnel.trycloudflare.com # Cloudflare tunnel URL (auto-set by scripts)

# ─── Observability (optional) ───────────────────
# LOG_LEVEL=info                                  # debug | info | warn | error
# REDIS_URL=redis://localhost:6379                # Falls back to in-memory cache
# NOTIFICATION_WEBHOOK_URL=https://hooks.slack.com/xxx # Slack/Discord webhook for alerts

# ─── Railway [HOST PROVIDED] ───────────────────────
# RAILWAY_GIT_COMMIT_SHA=                         # Set by Railway at deploy time
# RAILWAY_GIT_BRANCH=                             # Set by Railway at deploy time
# RAILWAY_DEPLOYMENT_CREATED_AT=                  # Set by Railway at deploy time
# COMMIT_SHA=                                     # Fallback commit SHA if not on Railway
